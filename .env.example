# =============================================
# ====== REQUIRED - این‌ها الزامی هستند ======
# =============================================

# ===== MongoDB =====
MONGODB_URI=mongodb://localhost:27017/cms-platform

# ===== Authentication Secrets =====
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex
CMS_ENCRYPTION_KEY=replace-with-64-char-random-hex

# =============================================
# ====== OPTIONAL - اختیاری ======
# =============================================

# ===== App URLs =====
# CMS/admin URL
# Development: http://localhost:3001
# Production: https://your-cms-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Public website/blog URL used for SEO-ready API output
NEXT_PUBLIC_SITE_NAME=Bozorgani
NEXT_PUBLIC_BLOG_BASE_URL=https://www.bozorgani.ir/blog

# ===== Security =====
# Comma-separated IP allowlist (leave empty for all)
ALLOWED_IPS=
# Trust X-Forwarded-For header (true for Vercel/proxies)
TRUST_PROXY=true

# ===== Telegram Notifications =====
# Create bot via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================
# ====== MEDIA STORAGE - Vercel Blob ======
# =============================================
# Current implementation uploads media to Vercel Blob and stores only the URL in MongoDB.
# Create a Blob store in Vercel and copy its Read/Write token here.
BLOB_READ_WRITE_TOKEN=
# Optional custom folder prefix inside Blob store
BLOB_FOLDER=cms/media
# Optional upload size limit in bytes (default: 10485760 = 10MB)
MAX_MEDIA_UPLOAD_SIZE=10485760

# ===== Alternative media providers (NOT implemented in current code) =====
# Cloudinary: CLOUDINARY_CLOUD_NAME + API_KEY + API_SECRET
# AWS S3:     AWS_* + S3_BUCKET
# ImageKit:   IMAGEKIT_* placeholders below
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_FOLDER=
