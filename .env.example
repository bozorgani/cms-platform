# ===== MongoDB =====
MONGODB_URI=mongodb://localhost:27017/cms-platform

# ===== Auth =====
JWT_SECRET=replace-with-64-char-random-hex-string-64-chars-long
CMS_ENCRYPTION_KEY=replace-with-64-char-random-hex-string-64-chars-long
JWT_EXPIRES_IN=7d

# ===== App URL =====
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ===== Security =====
ALLOWED_IPS=
TRUST_PROXY=true

# ===== Telegram Notifications =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== ImageKit (optional) =====
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_FOLDER=/cms
